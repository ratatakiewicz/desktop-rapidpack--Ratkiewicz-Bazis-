<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="RapidPack.MainWindow"
        Title="RapidPack"
        Width="380" Height="575" MinHeight="575" MinWidth="380" MaxWidth="380" MaxHeight="575"
        WindowStartupLocation="CenterScreen">

    <Border Background="#1A1A2E" Padding="32">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
              ColumnDefinitions="*,300,*"
              RowSpacing="12">

            
            <StackPanel Grid.Row="0" Grid.ColumnSpan="3"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20">
                <TextBlock Text="📦 Kalkulator Przesyłek"
                           FontSize="26" 
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Oblicz koszt swojej przesyłki"
                           FontSize="12"
                           Foreground="#8888AA"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>

            
            <Border Grid.Row="1" Grid.Column="1"
                    Background="#16213E"
                    BorderBrush="#444466"
                    BorderThickness="1.5"
                    CornerRadius="10"
                    Padding="16,12">
                <StackPanel Spacing="6">
                    <TextBlock Text="WAGA (kg)"
                               FontSize="11" 
                               FontWeight="Bold"
                               Foreground="#8888AA"
                               LetterSpacing="1"/>
                    <TextBox x:Name="WeightTextBox"
                             Watermark="0"/>
                </StackPanel>
            </Border>

            
            <Border Grid.Row="2" Grid.Column="1"
                    Background="#16213E"
                    BorderBrush="#444466"
                    BorderThickness="1.5"
                    CornerRadius="10"
                    Padding="16,12">
                <StackPanel Spacing="10">
                    <TextBlock Text="GABARYTY (cm)"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#8888AA"
                               LetterSpacing="1"/>
                    <Grid ColumnDefinitions="*,8,*,8,*">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Szerokość" 
                                       FontSize="11" 
                                       Foreground="#8888AA"/>
                            <TextBox x:Name="WidthTextBox" Watermark="0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Wysokość" 
                                       FontSize="11" 
                                       Foreground="#8888AA"/>
                            <TextBox x:Name="HeightTextBox" Watermark="0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" Spacing="4">
                            <TextBlock Text="Głębokość" 
                                       FontSize="11" 
                                       Foreground="#8888AA"/>
                            <TextBox x:Name="DepthTextBox" Watermark="0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            
            <Border Grid.Row="3" Grid.Column="1"
                    Background="#16213E"
                    BorderBrush="#444466"
                    BorderThickness="1.5"
                    CornerRadius="10"
                    Padding="16,12">
                <StackPanel Spacing="6">
                    <TextBlock Text="TYP PRZESYŁKI"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#8888AA"
                               LetterSpacing="1"/>
                    <ComboBox x:Name="ParcelTypeComboBox"
                              SelectedIndex="0"
                              HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="📦  Standardowa"/>
                        <ComboBoxItem Content="🔮  Ostrożnie (szkło)"/>
                        <ComboBoxItem Content="🪵  Paleta"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            
            <Border Grid.Row="4" Grid.Column="1"
                    Background="#16213E"
                    BorderBrush="#444466"
                    BorderThickness="1.5"
                    CornerRadius="10"
                    Padding="16,12">
                <CheckBox x:Name="ExpressCheckBox"
                          Foreground="White"
                          FontSize="13"
                          HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="⚡" FontSize="15"/>
                        <StackPanel>
                            <TextBlock Text="Dostawa ekspresowa" 
                                       Foreground="White" 
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="+15 zł" 
                                       Foreground="#8888AA" 
                                       FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </CheckBox>
            </Border>

            
            <Border Grid.Row="5" Grid.Column="1"
                    Height="1"
                    Background="#333355"
                    Margin="0,4"/>

            
            <Button Grid.Row="6" Grid.Column="1"
                    x:Name="CalculateButton"
                    Content="Wyceń przesyłkę →"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="0,16"
                    FontSize="15"
                    FontWeight="Bold"
                    Background="#5C6BC0"
                    Foreground="White"
                    CornerRadius="10"/>
        </Grid>
    </Border>
</Window>